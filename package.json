  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.3",
    "@react-native/eslint-config": "^0.73.0",
    "eslint": "^8.56.0"
  }
}
